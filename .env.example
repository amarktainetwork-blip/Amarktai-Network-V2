# ═══════════════════════════════════════════════════════════════
# AmarktAI Network V2 — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════

# ── Database (MariaDB) ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=amarktai
MYSQL_USER=amarktai
MYSQL_PASSWORD=CHANGE_ME_db_password
DATABASE_URL=mysql://amarktai:CHANGE_ME_db_password@mariadb:3306/amarktai

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Qdrant ──────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── Internal Search / Controlled Browser ───────────────────────
# SearXNG is an internal Network service and must not be exposed publicly.
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=CHANGE_ME_to_a_separate_random_secret
RESEARCH_SEARCH_TIMEOUT_MS=20000
RESEARCH_BROWSER_TIMEOUT_MS=45000
RESEARCH_ROBOTS_TIMEOUT_MS=10000
RESEARCH_MAX_REDIRECTS=5
RESEARCH_MAX_PAGES=8
RESEARCH_MAX_BYTES_PER_PAGE=1500000

# ── API Server ──────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_to_64_random_hex_characters
PROVIDER_KEY_ENCRYPTION_SECRET=CHANGE_ME_to_a_separate_64_random_hex_value
JWT_EXPIRY_SECONDS=86400
ADMIN_EMAIL=amarktainetwork@gmail.com
ADMIN_PASSWORD=
ADMIN_BOOTSTRAP_POLICY=required_if_missing

# ── Storage ─────────────────────────────────────────────────────
STORAGE_ROOT=/var/www/amarktai/storage

# ── Provider API Keys ───────────────────────────────────────────
# Runtime providers: GenX, Together, DeepInfra.
# MiMo is coding-agent-only and is never selected by the backend runtime.
# Groq has been removed and must not be configured.
TOGETHER_API_KEY=
GENX_API_KEY=
GENX_BASE_URL=https://query.genx.sh
MIMO_API_KEY=
DEEPINFRA_API_KEY=

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Worker ──────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_HEALTH_URL=http://worker:3002/health

# ── Next.js Dashboard ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://api:3001
API_URL=http://api:3001
PUBLIC_API_URL=https://api.example.com
NODE_ENV=production
