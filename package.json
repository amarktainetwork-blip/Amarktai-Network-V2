{
  "name": "amarktai-network",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run dev --workspace=@amarktai/api",
    "dev:worker": "npm run dev --workspace=@amarktai/worker",
    "build": "next build",
    "build:backend": "npm run build --workspace=@amarktai/core && npm run build --workspace=@amarktai/db && npm run build --workspace=@amarktai/providers && npm run build --workspace=@amarktai/artifacts && npm run build --workspace=@amarktai/sdk && npm run build --workspace=@amarktai/api && npm run build --workspace=@amarktai/worker",
    "test:sdk": "npm test --workspace=@amarktai/sdk",
    "start": "next start",
    "start:api": "npm run start --workspace=@amarktai/api",
    "start:worker": "npm run start --workspace=@amarktai/worker",
    "lint": "next lint",
    "lint:all": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:validate": "node scripts/prisma-validate.mjs",
    "prisma": "npm run prisma:validate",
    "proof": "node scripts/proof-release-fixture.mjs",
    "proof:deployment-static": "node scripts/proof-deployment-static.mjs",
    "proof:router-app-contract": "tsx scripts/proof-router-app-contract.mjs",
    "proof:long-form-runtime": "node scripts/proof-long-form-runtime.mjs",
    "proof:long-form-runtime:strict": "node scripts/proof-long-form-runtime.mjs --strict-runtime",
    "proof:live-execution": "node scripts/proof-live-execution.mjs",
    "proof:music-generation": "node scripts/proof-music-generation.mjs",
    "proof:music-regression": "vitest run tests/genx-music-contract.test.js tests/music-generation-foundation.test.js tests/music-reference-workflow-contract.test.js",
    "audit:completion": "tsx scripts/audit-build-completion-map.mjs",
    "audit": "npm run audit:completion",
    "discover": "npm run discover:models",
    "discover:models": "tsx scripts/discover-provider-models.mjs",
    "discover:models:live": "tsx scripts/discover-provider-models.mjs --live",
    "discover:models:live:strict": "tsx scripts/discover-provider-models.mjs --live --strict",
    "proof:authenticated-discovery": "node scripts/proof-authenticated-model-discovery.mjs",
    "proof:release-candidate": "node scripts/proof-release-candidate.mjs",
    "proof:release-fixture": "node scripts/proof-release-fixture.mjs",
    "proof:production-release-candidate": "node scripts/proof-production-release-candidate.mjs",
    "proof:avatar-app-onboarding": "node scripts/proof-avatar-app-onboarding.mjs",
    "proof:course2career-live": "node scripts/proof-course2career-live.mjs",
    "proof:second-advert-live": "node scripts/proof-second-advert-live.mjs",
    "proof:production-preflight": "node scripts/validate-production-preflight.mjs",
    "test:browser": "npm run test:browser:release-candidate",
    "test:browser:release-candidate": "playwright test tests/browser/release-candidate.spec.mjs",
    "worker": "node scripts/worker.mjs",
    "admin:reset-password": "node scripts/admin-reset-password.mjs",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:resolve": "prisma migrate resolve",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@xyflow/react": "^12.11.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.37.0",
    "ioredis": "^5.10.1",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.577.0",
    "next": "^15.5.19",
    "next-themes": "^0.4.6",
    "playwright": "^1.60.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "sentiment": "^5.0.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.22.4",
    "uuid": "^11.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sentiment": "^5.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.12",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "adm-zip": "0.6.0",
    "brace-expansion@>=2.0.0 <2.1.2": "2.1.2"
  }
}
