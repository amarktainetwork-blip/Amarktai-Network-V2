{
  "name": "amarktai-network",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run dev --workspace=@amarktai/api",
    "dev:worker": "npm run dev --workspace=@amarktai/worker",
    "build": "next build",
    "build:packages": "npm run build --workspace=@amarktai/core && npm run build --workspace=@amarktai/db && npm run build --workspace=@amarktai/artifacts",
    "build:api": "npm run build --workspace=@amarktai/api",
    "build:worker": "npm run build --workspace=@amarktai/worker",
    "build:all": "npm run build:packages && npm run build:api && npm run build:worker && npm run build",
    "postbuild": "node scripts/patch-manifests.mjs",
    "start": "next start",
    "start:api": "npm run start --workspace=@amarktai/api",
    "start:worker": "npm run start --workspace=@amarktai/worker",
    "lint": "next lint",
    "lint:all": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "proof": "npx tsx scripts/run-core-proof.ts",
    "worker": "node scripts/worker.mjs",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.37.0",
    "ioredis": "^5.10.1",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.577.0",
    "next": "^15.5.19",
    "nodemailer": "^8.0.5",
    "playwright": "^1.60.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "sentiment": "^5.0.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.22.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sentiment": "^5.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.12",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
